<Window x:Class="Taschenrechner_selber.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Taschenrechner_selber"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" PreviewTextInput="Window_PreviewTextInput" PreviewKeyDown="Window_PreviewKeyDown">
    
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="Input" TextAlignment="Right" VerticalContentAlignment="Center" FontSize="22" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,0,0,72" Height="73" Grid.RowSpan="2"/>
        <Button Grid.Column="0" Grid.Row="1" FontSize="22" Name="ButtonKAUF" Click="ButtonKAUF_Click">(</Button>
        <Button Grid.Column="0" Grid.Row="2" FontSize="22" Name="Button7" Click="Button7_Click">7</Button>
        <Button Grid.Column="0" Grid.Row="3" FontSize="22" Name="Button4" Click="Button4_Click">4</Button>
        <Button Grid.Column="0" Grid.Row="4" FontSize="22" Name="Button1" Click="Button1_Click">1</Button>
        <Button Grid.Column="0" Grid.Row="5" FontSize="22" Name="ButtonReturn" Click="ButtonReturn_Click">⌫</Button>
        <Button Grid.Column="1" Grid.Row="1" FontSize="22" Name="ButtonKZU" Click="ButtonKZU_Click">)</Button>
        <Button Grid.Column="1" Grid.Row="2" FontSize="22" Name="Button8" Click="Button8_Click">8</Button>
        <Button Grid.Column="1" Grid.Row="3" FontSize="22" Name="Button5" Click="Button5_Click">5</Button>
        <Button Grid.Column="1" Grid.Row="4" FontSize="22" Name="Button2" Click="Button2_Click">2</Button>
        <Button Grid.Column="1" Grid.Row="5" FontSize="22" Name="Button0" Click="Button0_Click">0</Button>
        <Button Grid.Column="2" Grid.Row="1" FontSize="22" Name="ButtonHoch" Click="ButtonHoch_Click">y^x</Button>
        <Button Grid.Column="2" Grid.Row="2" FontSize="22" Name="Button9" Click="Button9_Click">9</Button>
        <Button Grid.Column="2" Grid.Row="3" FontSize="22" Name="Button6" Click="Button6_Click">6</Button>
        <Button Grid.Column="2" Grid.Row="4" FontSize="22" Name="Button3" Click="Button3_Click">3</Button>
        <Button Grid.Column="2" Grid.Row="5" FontSize="22" Name="ButtonKomma" Click="ButtonKomma_Click" HorizontalAlignment="Right" Width="200">,</Button>
        <Button Grid.Column="3" Grid.Row="1" FontSize="22" Name="ButtonDividiert" Click="ButtonDividiert_Click">/</Button>
        <Button Grid.Column="3" Grid.Row="2" FontSize="22" Name="ButtonMal" Click="ButtonMal_Click">*</Button>
        <Button Grid.Column="3" Grid.Row="3" FontSize="22" Name="ButtonMinus" Click="ButtonMinus_Click">-</Button>
        <Button Grid.Column="3" Grid.Row="4" FontSize="22" Name="ButtonPlus" Click="ButtonPlus_Click">+</Button>
        <Button Grid.Column="3" Grid.Row="5" FontSize="22" Name="ButtonGleich" Click="ButtonGleich_Click">=</Button>
    </Grid>
    
</Window>
