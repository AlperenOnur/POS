<Window x:Class="Ultimatives_Osterhasen_Hilfs_Programm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ultimatives_Osterhasen_Hilfs_Programm"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Menu  Grid.Row="0">
            <MenuItem Header="Datenbank">
                <MenuItem Header="Personen erstellen" Click="CreatePerson_Click"></MenuItem>
            </MenuItem>
            <MenuItem Header="Visualisierung">
                <MenuItem Header="Punkte einzeichnen (Grundvisualisierung)" Click="VisualizePoints_Click"></MenuItem>
                <MenuItem Header="Helfer berechnen und einzeichnen" Click="VisualizeHelfer_Click"></MenuItem>
                <MenuItem Header="Weg für Helfer berechnen (danach Klick auf Punkt)" Click="VisualizeWeg_Click"></MenuItem>

            </MenuItem>
        </Menu>
        <Canvas Grid.Row="1" Name="Map"  SizeChanged="Map_SizeChanged">
            <Canvas.Background >
                <ImageBrush  ImageSource="/ressources/Stadtplan-Wiener-Neustadt.jpg"></ImageBrush>
            </Canvas.Background>
        </Canvas>
    </Grid>
</Window>
