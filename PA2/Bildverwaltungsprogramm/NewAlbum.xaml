<Window x:Class="Bildverwaltungsprogramm.NewAlbum"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bildverwaltungsprogramm"
        mc:Ignorable="d"
        Title="NewAlbum" Height="175" Width="200">
    <Grid>
        <StackPanel>
            <Label Content="Album hinzufügen"></Label>
            <Label Content="Name:"></Label>
            <TextBox x:Name="Albumname" TextChanged="Albumname_TextChanged"></TextBox>
            <Label x:Name="Labelshow" Content="Album existiert bereits!" Foreground="Red"></Label>
            <Button x:Name="Add_Button" Content="Hinzufügen" Click="Button_Click"></Button>
        </StackPanel>
    </Grid>
</Window>
