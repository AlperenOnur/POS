<Window x:Class="Bildverwaltungsprogramm.MovePics"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bildverwaltungsprogramm"
        mc:Ignorable="d"
        Title="MovePics" Height="200" Width="200">
    <Grid>
        <StackPanel>
            <Label Content="Bilder verschieben"></Label>
            <Label Content="Zielalbum:"></Label>
            <ComboBox x:Name="Comboboxalben"></ComboBox>
            <Line Height="20"></Line>
            <Button x:Name="finishbutton" Click="finishbutton_Click" Content="Bilder verschieben"></Button>
        </StackPanel>
    </Grid>
</Window>
