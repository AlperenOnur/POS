<Window x:Class="Bildverwaltungsprogramm.AddPics"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bildverwaltungsprogramm"
        mc:Ignorable="d"
        Title="AddPics" Height="175" Width="300">
    <Grid>
        <StackPanel>
            <Button x:Name="choosezipbutton" Content="Zip Folder wählen" Click="choosezipbutton_Click"></Button>
            <Label Content="Gewählter Zip-Ordner: " x:Name="showlabel"></Label>
            <Label Content="Zielalbum:"></Label>
            <ComboBox x:Name="ComboAlben"></ComboBox>
            <Line Height="20"></Line>
            <Button x:Name="finishbutton" Content="Bilder hinzufügen" Click="finishbutton_Click"></Button>
        </StackPanel>
    </Grid>
</Window>
