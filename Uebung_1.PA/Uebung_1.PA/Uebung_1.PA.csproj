<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="ressources\Code1.txt" />
    <None Remove="ressources\Code2.txt" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="AbcRobotCore">
      <HintPath>..\AbcRobotCore.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="ressources\Code1.txt" />
    <Resource Include="ressources\Code2.txt" />
  </ItemGroup>

  <ItemGroup>
    <None Update="ressources\Map1.xml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="ressources\Map2.xml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
